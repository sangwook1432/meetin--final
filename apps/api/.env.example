APP_NAME=MEETIN API
ENV=local             # local | staging | production
DEBUG=true

DATABASE_URL=postgresql+psycopg://USER:PASSWORD@localhost:5432/meetin

JWT_SECRET=CHANGE_ME_random_secret_at_least_32_chars
JWT_ALG=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14

PHONE_HMAC_SECRET=CHANGE_ME_phone_hmac_secret_32_chars

ADMIN_EMAILS=admin@meetin.kr,dev@meetin.kr

ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

TOSS_SECRET_KEY=
TOSS_CLIENT_KEY=

KAKAO_API_KEY=
KAKAO_SENDER_KEY=

KAKAO_TPL_WAITING_CONFIRM=MEETIN_WAIT
KAKAO_TPL_CONFIRMED=MEETIN_CONF
KAKAO_TPL_REFUNDED=MEETIN_RFND
KAKAO_TPL_FORFEITED=MEETIN_FORF
KAKAO_TPL_REPLACEMENT=MEETIN_REPL

REDIS_URL=
# REDIS_URL=redis://localhost:6379/0
# REDIS_URL=rediss://default:PASSWORD@your-redis-host:6380/0  (TLS)

SENTRY_DSN=
