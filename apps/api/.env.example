ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14

PHONE_HMAC_SECRET=CHANGE_ME_phone_hmac_secret_32_chars

ADMIN_USERNAMES=adamjeon2003

ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

TOSS_SECRET_KEY=
TOSS_CLIENT_KEY=

KAKAO_API_KEY=
KAKAO_SENDER_KEY=

KAKAO_TPL_WAITING_CONFIRM=MEETIN_WAIT
