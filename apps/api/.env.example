APP_NAME=MEETIN API
ENV=local             # local | staging | production
DEBUG=true

DATABASE_URL=postgresql+psycopg://USER:PASSWORD@localhost:5432/meetin

JWT_SECRET=CHANGE_ME_random_secret_at_least_32_chars
JWT_ALG=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14

PHONE_HMAC_SECRET=CHANGE_ME_phone_hmac_secret_32_chars

ADMIN_USERNAMES=adamjeon2003

ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

TOSS_SECRET_KEY=
TOSS_CLIENT_KEY=

KAKAO_API_KEY=
KAKAO_SENDER_KEY=

# SOLAPI SMS (사전예약 OTP 인증)
# https://developers.solapi.com 에서 API 키 발급
# 미설정 시 mock 모드 (OTP=000000, 발송 없음)
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_FROM_NUMBER=

REDIS_URL=
# REDIS_URL=redis://localhost:6379/0
# REDIS_URL=rediss://default:PASSWORD@your-redis-host:6380/0  (TLS)

SENTRY_DSN=

R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=meetin-uploads
R2_PUBLIC_URL=https://pub-<token>.r2.dev
