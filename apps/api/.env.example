# ─────────────────────────────────────────
# MEETIN API — 환경변수 예시
# 실제 .env 파일을 이 파일을 복사해서 만드세요: cp .env.example .env
# ⚠️  .env 는 절대 git에 커밋하지 마세요
# ─────────────────────────────────────────

# 앱
APP_NAME=MEETIN API
ENV=local           # local | staging | production
DEBUG=true

# 데이터베이스 (PostgreSQL)
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@localhost:5432/meetin

# JWT
JWT_SECRET=change-me-to-a-long-random-secret-in-production
JWT_ALG=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14

# 전화번호 HMAC (전화번호 해시 저장용)
PHONE_HMAC_SECRET=change-me-to-another-long-random-secret

# 관리자 이메일 (콤마 구분)
ADMIN_EMAILS=admin@meetin.kr

# CORS 허용 origin (콤마 구분)
# 로컬: http://localhost:3000
# 프로덕션: https://meetin.kr,https://www.meetin.kr
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── Toss Payments ───────────────────────────────────────────────
# https://developers.tosspayments.com/ 에서 발급
TOSS_SECRET_KEY=test_sk_...        # 시크릿 키 (서버 전용)
TOSS_CLIENT_KEY=test_ck_...        # 클라이언트 키 (프론트 노출 가능)

# ─── 카카오 알림톡 ────────────────────────────────────────────────
# https://business.kakao.com/ 비즈메시지 채널 등록 후 발급
KAKAO_API_KEY=                     # REST API 키
KAKAO_SENDER_KEY=                  # 알림톡 발신 프로필 키

# 알림톡 템플릿 코드 (카카오 채널에서 승인된 템플릿 코드 입력)
KAKAO_TPL_WAITING_CONFIRM=MEETIN_WAIT
KAKAO_TPL_CONFIRMED=MEETIN_CONF
KAKAO_TPL_REFUNDED=MEETIN_RFND
KAKAO_TPL_FORFEITED=MEETIN_FORF
KAKAO_TPL_REPLACEMENT=MEETIN_REPL

# ─── Sentry 에러 모니터링 ─────────────────────────────────────────
# https://sentry.io/ 에서 프로젝트 생성 후 DSN 복사
SENTRY_DSN=                        # 비워두면 비활성화
